{
  "name": "@patina/client-portal",
  "version": "0.1.0",
  "private": true,
  "description": "Patina Client Portal - Mobile-first project timeline and collaboration",
  "scripts": {
    "dev": "next dev -p 3002",
    "build": "next build",
    "start": "next start -p 3002",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "clean": "rm -rf .next",
    "analyze": "ANALYZE=true next build",
    "lighthouse": "lighthouse http://localhost:3002 --view --preset=desktop",
    "lighthouse:mobile": "lighthouse http://localhost:3002 --view --preset=mobile",
    "security:test": "./scripts/test-security-headers.sh dev",
    "security:test:prod": "./scripts/test-security-headers.sh prod",
    "security:audit": "pnpm audit --audit-level=moderate",
    "security:audit:fix": "pnpm audit --fix"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^3.9.0",
    "@patina/api-routes": "workspace:*",
    "@patina/design-system": "workspace:*",
    "@patina/supabase": "workspace:*",
    "@patina/types": "workspace:*",
    "@patina/utils": "workspace:*",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.6",
    "@radix-ui/react-toast": "^1.2.7",
    "@react-pdf/renderer": "^4.3.1",
    "@tanstack/react-query": "^5.17.19",
    "@tanstack/react-query-devtools": "^5.17.19",
    "axios": "^1.6.5",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.0",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^11.0.8",
    "lucide-react": "^0.544.0",
    "next": "^15.0.0",
    "next-pwa": "^5.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.52.1",
    "react-intersection-observer": "^9.16.0",
    "react-pdf": "^10.2.0",
    "react-use-gesture": "^9.1.3",
    "signature_pad": "^5.1.1",
    "socket.io-client": "^4.8.1",
    "tailwind-merge": "^2.2.1",
    "uuid": "^10.0.0",
    "vaul": "^0.9.0",
    "zod": "^3.22.4",
    "zustand": "^4.5.0",
    "@patina/auth": "workspace:*",
    "@patina/api-client": "workspace:*"
  },
  "devDependencies": {
    "@playwright/test": "^1.41.1",
    "@testing-library/jest-dom": "^6.2.0",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20.11.19",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "autoprefixer": "^10.4.17",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lighthouse": "^11.5.0",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "web-vitals": "^5.1.0",
    "webpack-bundle-analyzer": "^4.10.2"
  }
