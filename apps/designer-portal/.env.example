# ============================================
# PATINA DESIGNER PORTAL - ENVIRONMENT VARIABLES
# ============================================
# SECURITY: Never commit .env files with real credentials to version control

# --------------------------------------------
# Supabase Configuration (Required)
# --------------------------------------------
# Public Supabase URL and anon key (safe for browser)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Production:
# NEXT_PUBLIC_SUPABASE_URL=https://api.patina.cloud
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-production-anon-key

# Server-side only — service role key (NEVER expose to browser)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --------------------------------------------
# Backend Service URLs (Server-side Only)
# --------------------------------------------
# Used by Next.js API routes to proxy to retained NestJS services
# NOT exposed to the browser (no NEXT_PUBLIC_ prefix)
ORDERS_SERVICE_URL=http://localhost:3015
MEDIA_SERVICE_URL=http://localhost:3014
PROJECTS_SERVICE_URL=http://localhost:3016

# Coolify: Use container names for inter-service communication
# ORDERS_SERVICE_URL=http://orders:3015
# MEDIA_SERVICE_URL=http://media:3014
# PROJECTS_SERVICE_URL=http://projects:3016

# --------------------------------------------
# Application URLs
# --------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Production:
# NEXT_PUBLIC_APP_URL=https://app.patina.cloud

# --------------------------------------------
# PostHog Analytics (Optional)
# --------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --------------------------------------------
# Feature Flags (Optional)
# --------------------------------------------
NEXT_PUBLIC_ENABLE_TEACHING=true
NEXT_PUBLIC_ENABLE_CAMPAIGNS=true
NEXT_PUBLIC_ENABLE_ROOM_SCANS=true
NEXT_PUBLIC_ENABLE_INSIGHTS=true
NEXT_PUBLIC_ENABLE_MESSAGING=true
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_DEBUG=false

# --------------------------------------------
# Real-time Communication (Optional)
# --------------------------------------------
# Supabase Realtime is used by default for real-time features.
# WebSocket URL only needed for the projects NestJS service (Socket.IO)
NEXT_PUBLIC_WS_URL=ws://localhost:3016
NEXT_PUBLIC_ENABLE_REAL_TIME=true

# Production:
# NEXT_PUBLIC_WS_URL=wss://api.patina.cloud/projects

# --------------------------------------------
# Media & CDN (Optional)
# --------------------------------------------
NEXT_PUBLIC_CDN_URL=
NEXT_PUBLIC_MEDIA_BUCKET=media

# --------------------------------------------
# Environment
# --------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_ENV=development
