{
  "name": "@patina/extension",
  "displayName": "Patina Capture",
  "version": "0.1.0",
  "description": "Capture furniture products for your Patina catalog",
  "author": "Patina",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@plasmohq/storage": "^1.15.0",
    "@patina/shared": "workspace:*",
    "@supabase/supabase-js": "^2.43.0",
    "plasmo": "^0.90.5",
    "posthog-js": "^1.356.1",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/chrome": "^0.0.268",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "jsdom": "^24.0.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.0",
    "vitest": "^4.0.17"
  },
  "manifest": {
    "permissions": [
      "activeTab",
      "cookies",
      "storage",
      "contextMenus",
      "scripting",
      "sidePanel",
      "alarms"
    ],
    "host_permissions": [
      "https://*/*",
      "http://*/*"
    ]
  }
}
