# =============================================================================
# Patina Coolify Deployment - Environment Variables Template
# =============================================================================
# Copy this file to .env.coolify and fill in production values.
# Used by coolify-setup.sh (API automation) and coolify-deploy.sh (orchestration).
#
# Key differences from local development:
# - Single Supabase DB with schema-per-service isolation (not separate databases)
# - Container names for inter-service communication (not localhost)
# - Traefik handles SSL/routing (replaces NGINX)
# - Supabase Auth (not NextAuth) — no NEXTAUTH_URL or AUTH_SECRET needed
#
# Note: The Coolify project may be named "Strata".
# =============================================================================

# -----------------------------------------------------------------------------
# Coolify API Configuration (used by coolify-setup.sh)
# -----------------------------------------------------------------------------
# COOLIFY_FQDN=http://your-coolify-server:8000
# COOLIFY_TOKEN=<api-token-from-settings-keys-and-tokens>
# COOLIFY_PROJECT_UUID=<from GET /api/v1/projects>
# COOLIFY_SERVER_UUID=<from GET /api/v1/servers>
# COOLIFY_ENVIRONMENT=production

# Git repository (for Dockerfile-based service deployments)
# GIT_REPOSITORY=https://github.com/your-org/patina.git
# GIT_BRANCH=main

# -----------------------------------------------------------------------------
# Shared Secrets (same across all services)
# Generate each with: openssl rand -base64 48
# -----------------------------------------------------------------------------
# POSTGRES_PASSWORD=<supabase-postgres-password>
# JWT_SECRET=<shared-across-all-backend-services-and-supabase>
# REDIS_PASSWORD=<redis-password>

# -----------------------------------------------------------------------------
# Supabase Auth (replaces NextAuth)
# Generate keys at: supabase.com/docs/guides/hosting/jwt-generator
# -----------------------------------------------------------------------------
# ANON_KEY=<supabase-anon-key>
# SERVICE_ROLE_KEY=<supabase-service-role-key>
# NEXT_PUBLIC_SUPABASE_URL=https://api.patina.cloud
# NEXT_PUBLIC_SUPABASE_ANON_KEY=${ANON_KEY}

# Supabase Studio
# DASHBOARD_USERNAME=supabase
# DASHBOARD_PASSWORD=<strong-password>

# Supabase Auth settings
# SITE_URL=https://app.patina.cloud
# API_EXTERNAL_URL=https://api.patina.cloud

# -----------------------------------------------------------------------------
# Database URLs (per service, schema-isolated)
# Format: postgresql://postgres:PASS@supabase-db:5432/postgres?schema=SCHEMA
# Port 5432 = Direct (for migrations/prisma db push and app connections)
# -----------------------------------------------------------------------------
# orders:     schema=svc_orders
# media:      schema=svc_media
# projects:   schema=svc_projects
#
# Example for orders service:
# DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@supabase-db:5432/postgres?schema=svc_orders

# -----------------------------------------------------------------------------
# Infrastructure Services (Coolify container names)
# -----------------------------------------------------------------------------
# REDIS_HOST=patina-redis
# REDIS_PORT=6379
# MINIO_ENDPOINT=http://patina-minio:9000

# MinIO credentials
# MINIO_ROOT_USER=patina
# MINIO_ROOT_PASSWORD=<minio-password>
# S3_BUCKET=patina-media
# S3_REGION=us-east-1

# -----------------------------------------------------------------------------
# Inter-Service URLs (Coolify internal network, by container name)
# Only 3 backend services in the merged architecture.
# -----------------------------------------------------------------------------
# ORDERS_SERVICE_URL=http://patina-orders:3015
# MEDIA_SERVICE_URL=http://patina-media:3014
# PROJECTS_SERVICE_URL=http://patina-projects:3016

# -----------------------------------------------------------------------------
# Service-Specific Configuration
# -----------------------------------------------------------------------------

# Orders service — Stripe + EasyPost
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# EASYPOST_API_KEY=EZAK...

# Media service — uses MinIO config above

# Projects service — no additional config needed

# -----------------------------------------------------------------------------
# Frontend Domains (Traefik routes with auto SSL via Let's Encrypt)
# designer-portal is now app.patina.cloud (not designer.patina.cloud)
# -----------------------------------------------------------------------------
# designer-portal: app.patina.cloud     (port 3000)
# admin-portal:    admin.patina.cloud   (port 3001)
# client-portal:   client.patina.cloud  (port 3002)

# -----------------------------------------------------------------------------
# CORS (production domains)
# -----------------------------------------------------------------------------
# CORS_ORIGINS=https://app.patina.cloud,https://admin.patina.cloud,https://client.patina.cloud

# -----------------------------------------------------------------------------
# Email (via Supabase Auth SMTP)
# -----------------------------------------------------------------------------
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_USER=resend
# SMTP_PASS=<resend-api-key>
# SMTP_ADMIN_EMAIL=hello@patina.cloud

# -----------------------------------------------------------------------------
# Optional: Analytics, Feature Flags
# -----------------------------------------------------------------------------
# POSTHOG_KEY=
# POSTHOG_HOST=
# NEXT_PUBLIC_FEATURE_TEACHING=false
# NEXT_PUBLIC_FEATURE_ROOM_SCANS=false
# NEXT_PUBLIC_FEATURE_CAMPAIGNS=false
