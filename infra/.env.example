# =============================================================================
# PATINA PRODUCTION ENVIRONMENT VARIABLES
# =============================================================================
# Copy to .env and fill in values before deploying.
# Generate secrets: openssl rand -base64 32
# =============================================================================

# -----------------------------------------------------------------------------
# SUPABASE (self-hosted)
# -----------------------------------------------------------------------------
POSTGRES_PASSWORD=              # openssl rand -base64 24
JWT_SECRET=                     # openssl rand -base64 32 (must match Supabase config)
ANON_KEY=                       # Generate at supabase.com/docs/guides/hosting/jwt-generator
SERVICE_ROLE_KEY=               # Generate at supabase.com/docs/guides/hosting/jwt-generator

# Supabase URLs (public-facing via Cloudflare Tunnel)
NEXT_PUBLIC_SUPABASE_URL=https://api.patina.cloud
NEXT_PUBLIC_SUPABASE_ANON_KEY=${ANON_KEY}

# Supabase Studio
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=             # Strong password for Studio access

# Supabase Auth
SITE_URL=https://app.patina.cloud
API_EXTERNAL_URL=https://api.patina.cloud
ADDITIONAL_REDIRECT_URLS=https://app.patina.cloud,https://admin.patina.cloud,https://client.patina.cloud,patina://

# Supabase Realtime
REALTIME_SECRET_KEY_BASE=       # openssl rand -base64 64

# -----------------------------------------------------------------------------
# REDIS
# -----------------------------------------------------------------------------
REDIS_PASSWORD=                 # openssl rand -base64 16

# -----------------------------------------------------------------------------
# MINIO (S3-compatible object storage)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=patina
MINIO_ROOT_PASSWORD=            # openssl rand -base64 24
MINIO_CONSOLE_URL=https://storage-admin.patina.cloud
S3_BUCKET=patina-media
S3_REGION=us-east-1

# -----------------------------------------------------------------------------
# NESTJS SERVICES (server-side only)
# -----------------------------------------------------------------------------

# Orders Service
STRIPE_SECRET_KEY=              # sk_live_... or sk_test_...
STRIPE_WEBHOOK_SECRET=          # whsec_...
EASYPOST_API_KEY=               # EZAK...

# Media Service — uses MinIO config above

# Projects Service — no additional config needed

# -----------------------------------------------------------------------------
# FRONTEND APPS
# -----------------------------------------------------------------------------

# App URLs (for CORS, redirects, metadata)
DESIGNER_APP_URL=https://app.patina.cloud
ADMIN_APP_URL=https://admin.patina.cloud
CLIENT_APP_URL=https://client.patina.cloud

# PostHog Analytics (optional)
POSTHOG_KEY=
POSTHOG_HOST=

# Feature Flags (optional)
NEXT_PUBLIC_FEATURE_TEACHING=false
NEXT_PUBLIC_FEATURE_ROOM_SCANS=false
NEXT_PUBLIC_FEATURE_CAMPAIGNS=false

# -----------------------------------------------------------------------------
# EMAIL (via Supabase Auth SMTP or Resend)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=                      # Resend API key
SMTP_ADMIN_EMAIL=hello@patina.cloud

# -----------------------------------------------------------------------------
# CLOUDFLARE TUNNEL
# -----------------------------------------------------------------------------
TUNNEL_ID=                      # From: cloudflared tunnel list
TUNNEL_TOKEN=                   # From: cloudflared tunnel token <tunnel-name>
