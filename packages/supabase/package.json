{
  "name": "@patina/supabase",
  "version": "0.0.1",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./server": "./src/server.ts",
    "./hooks": "./src/hooks/index.ts"
  },
  "scripts": {
    "generate": "supabase gen types typescript --db-url \"$SUPABASE_DB_URL\" > src/database.types.ts",
    "push": "supabase db push --db-url \"$SUPABASE_DB_URL\"",
    "studio": "supabase studio",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@patina/shared": "workspace:*",
    "@supabase/ssr": "^0.3.0",
    "@supabase/supabase-js": "^2.43.0",
    "@tanstack/react-query": "^5.40.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.8",
    "msw": "^2.3.0",
    "supabase": "^2.67.1",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {
    "next": ">=14.0.0",
    "react": "^18.0.0 || ^19.0.0"
  }
}
