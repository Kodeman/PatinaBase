# Application
NODE_ENV=development
PORT=3015
SERVICE_NAME=orders

# Database — Unified Supabase PostgreSQL
# All services share the same Supabase Postgres, isolated by search_path schema
DATABASE_URL="postgresql://postgres:your-super-secret-password@localhost:54322/postgres?schema=svc_orders&connection_limit=20&pool_timeout=20"
DIRECT_URL="postgresql://postgres:your-super-secret-password@localhost:54322/postgres?schema=svc_orders"

# Production (Coolify): Use Supavisor connection pooler
# DATABASE_URL=postgresql://postgres:SUPABASE_DB_PASSWORD@supabase-db:6543/postgres?schema=svc_orders&pgbouncer=true&connection_limit=10
# DIRECT_URL=postgresql://postgres:SUPABASE_DB_PASSWORD@supabase-db:5432/postgres?schema=svc_orders

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=patina_redis_password
REDIS_DB=2

# Coolify: Use container name for Redis
# REDIS_HOST=redis

# Stripe
# SECURITY: Never commit real Stripe keys. Use test keys for development.
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_STRIPE_TEST_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_WITH_YOUR_STRIPE_TEST_PUBLISHABLE_KEY
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_STRIPE_WEBHOOK_SECRET
STRIPE_API_VERSION=2023-10-16

# Shipping / Fulfillment
CARRIER_PROVIDER=easypost
EASYPOST_API_KEY=EZAK_test_REPLACE_WITH_YOUR_EASYPOST_TEST_API_KEY
EASYPOST_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_EASYPOST_WEBHOOK_SECRET
EASYPOST_MODE=test
EASYPOST_DEFAULT_FROM_ADDRESS_ID=addr_REPLACE_WITH_YOUR_ADDRESS_ID

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# Production:
# CORS_ORIGINS=https://app.patina.cloud,https://admin.patina.cloud,https://client.patina.cloud

# Security - Supabase JWT Authentication
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# Cart Settings
CART_EXPIRY_DAYS=30
CART_CACHE_TTL_SECONDS=3600

# Order Settings
ORDER_NUMBER_PREFIX=ORD
PAYMENT_TIMEOUT_MINUTES=30

# Reconciliation
RECONCILIATION_CRON=0 */6 * * *
RECONCILIATION_WINDOW_HOURS=24

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=60

# Logging
LOG_LEVEL=info
