    "@nestjs/jwt": "^10.2.0",
    "@nestjs/microservices": "^10.4.20",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.20",
    "@nestjs/swagger": "^7.4.2",
    "@willsoto/nestjs-prometheus": "^6.0.2",
