# Application
NODE_ENV=development
PORT=3014
SERVICE_NAME=media
API_URL=http://localhost:3014

# Database — Unified Supabase PostgreSQL
# All services share the same Supabase Postgres, isolated by search_path schema
DATABASE_URL=postgresql://postgres:your-super-secret-password@localhost:54322/postgres?schema=svc_media&connection_limit=20&pool_timeout=20
DIRECT_URL=postgresql://postgres:your-super-secret-password@localhost:54322/postgres?schema=svc_media

# Production (Coolify): Use Supavisor connection pooler
# DATABASE_URL=postgresql://postgres:SUPABASE_DB_PASSWORD@supabase-db:6543/postgres?schema=svc_media&pgbouncer=true&connection_limit=10
# DIRECT_URL=postgresql://postgres:SUPABASE_DB_PASSWORD@supabase-db:5432/postgres?schema=svc_media

# Redis (for BullMQ job queues)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=patina_redis_password
REDIS_DB=6

# Coolify: Use container name for Redis
# REDIS_HOST=redis

# MinIO (S3-compatible for local development)
MINIO_ENDPOINT=http://localhost:9000
# Coolify: Use container name for MinIO
# MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=patina_minio
MINIO_SECRET_KEY=patina_minio_password
MINIO_BUCKET_MEDIA=media

# Object Storage
# Provider selection: R2 for production (Cloudflare R2), S3 for local dev (MinIO above)
STORAGE_PROVIDER=S3

# Cloudflare R2 (production)
# Create buckets in the Cloudflare dashboard and an R2 API token with
# Object Read/Write on each bucket.
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_RAW=patina-raw
# R2_BUCKET_PROCESSED=patina-processed
# R2_BUCKET_THUMBNAILS=patina-thumbnails
# R2_BUCKET_ARCHIVE=patina-archive
# R2_PUBLIC_BUCKET_URL=https://cdn.patina.cloud
# At bootstrap, R2_BUCKET_RAW/PROCESSED are aliased to the legacy
# OCI_BUCKET_RAW/PROCESSED/PUBLIC/MEDIA names used by older callers.

# CDN
CDN_DOMAIN=cdn.patina.cloud
CDN_PROVIDER=cloudflare
# CF_API_TOKEN= # for cache purge via CloudflareCDNProvider
CDN_SIGNING_ENABLED=false
CDN_SIGNING_KEY=

# Image Processing
IMGPROXY_URL=http://localhost:8080
IMGPROXY_KEY=
IMGPROXY_SALT=

# Virus Scanning (ClamAV)
# Set to false for local development without ClamAV
# Set to true for production with ClamAV running
VIRUS_SCAN_ENABLED=false
CLAMAV_HOST=localhost
CLAMAV_PORT=3310

# Security - Supabase JWT Authentication
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# Media Processing
MAX_IMAGE_SIZE_MB=25
MAX_VIDEO_SIZE_MB=100
MAX_3D_SIZE_MB=25

# CORS Configuration
# SECURITY: Restrict CORS to trusted domains only in production
# Development: http://localhost:3000,http://localhost:3001,http://localhost:3002
# Production: https://patina.cloud,https://admin.patina.cloud,https://client.patina.cloud,https://api.patina.cloud
CORS_ORIGINS=https://patina.cloud,https://admin.patina.cloud,https://client.patina.cloud,https://api.patina.cloud

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=50

# Feature Flags
BACKGROUND_REMOVAL_ENABLED=false
3D_PROCESSING_ENABLED=true
SIGNED_CDN_ENABLED=false

# Logging
LOG_LEVEL=debug
