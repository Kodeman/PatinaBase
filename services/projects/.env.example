# Application
NODE_ENV=development
PORT=3016
SERVICE_NAME=projects

# Database — Unified Supabase PostgreSQL
# All services share the same Supabase Postgres, isolated by search_path schema
DATABASE_URL="postgresql://postgres:your-super-secret-password@localhost:54322/postgres?schema=svc_projects&connection_limit=20&pool_timeout=20"
DIRECT_URL="postgresql://postgres:your-super-secret-password@localhost:54322/postgres?schema=svc_projects"

# Production (Coolify): Use Supavisor connection pooler
# DATABASE_URL=postgresql://postgres:SUPABASE_DB_PASSWORD@supabase-db:6543/postgres?schema=svc_projects&pgbouncer=true&connection_limit=10
# DIRECT_URL=postgresql://postgres:SUPABASE_DB_PASSWORD@supabase-db:5432/postgres?schema=svc_projects

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
# Local dev default matches docker-compose.yml: patina_redis_password
REDIS_PASSWORD=patina_redis_password

# Coolify: Use container name for Redis
# REDIS_HOST=redis

# Inter-service communication (retained NestJS services only)
ORDERS_SERVICE_URL=http://localhost:3015
MEDIA_SERVICE_URL=http://localhost:3014

# Coolify: Use container names
# ORDERS_SERVICE_URL=http://orders:3015
# MEDIA_SERVICE_URL=http://media:3014

# CORS Configuration
# SECURITY: Restrict CORS to trusted domains only in production
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# Production:
# CORS_ORIGINS=https://app.patina.cloud,https://admin.patina.cloud,https://client.patina.cloud

# Security - Supabase JWT Authentication
# The JWT secret from your Supabase instance (found in supabase/config.toml or dashboard)
# For local dev with `supabase start`, this is the default:
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
# Legacy alias (will fall back to this if SUPABASE_JWT_SECRET is not set)
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=60

# Logging
LOG_LEVEL=debug
