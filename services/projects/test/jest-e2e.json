{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@patina/cache$": "<rootDir>/../../../packages/cache/src",
    "^@patina/cache/(.*)$": "<rootDir>/../../../packages/cache/src/$1"
  }
}
