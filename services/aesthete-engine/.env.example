# Application
ENV=development
SERVICE_NAME=aesthete-engine
VERSION=1.0.0
LOG_LEVEL=INFO
PORT=8000

# Database
DATABASE_URL=postgresql+asyncpg://patina:STRONG_PASSWORD@localhost:5432/patina
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# Coolify/Supabase: Single DB with schema isolation
# DATABASE_URL=postgresql+asyncpg://postgres:SUPABASE_DB_PASSWORD@supabase-db:5432/postgres?options=-c%20search_path%3Dsvc_aesthete

# Redis
REDIS_URL=redis://localhost:6379/0

# Coolify: Use container name for Redis
# REDIS_URL=redis://:REDIS_PASSWORD@redis:6379/0
REDIS_MAX_CONNECTIONS=50

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_ARTIFACT_URI=s3://patina-mlflow-artifacts
MLFLOW_S3_ENDPOINT_URL=https://objectstorage.us-ashburn-1.oraclecloud.com

# OpenSearch
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200

# Coolify: Use container name for OpenSearch
# OPENSEARCH_HOST=opensearch
OPENSEARCH_USE_SSL=true
OPENSEARCH_VERIFY_CERTS=true

# Model Configuration
EMBEDDING_MODEL_NAME=clip-vit-b-32
EMBEDDING_DIM=768
SCORE_VEC_DIM=32
ALPHA_IMG_TEXT=0.6

# Scoring Weights (default)
WEIGHT_VEC=0.45
WEIGHT_TEXT=0.10
WEIGHT_PRICE=0.10
WEIGHT_SIZE=0.10
WEIGHT_RULES=0.15
WEIGHT_POP=0.05
WEIGHT_NEW=0.05
WEIGHT_PENALTY=0.30

# Performance
VECTOR_TOP_K=500
LEXICAL_TOP_K=300
DEFAULT_LIMIT=20
CACHE_TTL_SECONDS=600
BATCH_SIZE=32

# Observability
OTLP_ENDPOINT=http://localhost:4318
ENABLE_TRACING=true
ENABLE_METRICS=true

# Feature Flags
ENABLE_MMR_DIVERSITY=true
MMR_LAMBDA=0.8
ENABLE_PRECOMPUTE=true
ENABLE_EXPLAINABILITY=true

# Rate Limiting
RATE_LIMIT_RECOMMENDATIONS=30  # per minute per user
RATE_LIMIT_FEEDBACK=120  # per minute per user
